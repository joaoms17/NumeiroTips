# ==========================================================================
# NumeiroTips — variáveis de ambiente
# Copia para .env.local (frontend) e configura no Supabase / Vercel.
# A app FUNCIONA SEM NENHUMA destas chaves: cai no motor mock local
# (dados simulados realistas) para validar o pipeline de ponta a ponta.
# ==========================================================================

# --- Frontend (Vite, prefixo VITE_) ---
# Supabase (opcional no MVP; sem isto a app usa o motor mock local)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Modo de dados: "mock" (default) usa o gerador local; "live" usa Supabase realtime
VITE_DATA_MODE=mock

# --- Backend / Edge Functions (NUNCA expor no frontend) ---
# OddsPapi — fonte normalizada (Betclic, 1xBet, Pinnacle, Betfair)
# Conta B2B/paga; WebSocket só no tier Pro (o REST polling chega para pré-jogo).
ODDSPAPI_API_KEY=
ODDSPAPI_BASE_URL=https://api.oddspapi.io/v1
ODDSPAPI_WS_URL=wss://stream.oddspapi.io/v1

# Supabase service role (só no servidor / edge functions)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# URL da Edge Function scan-odds (para o Vercel Cron a acionar)
SUPABASE_FUNCTION_URL=https://<projeto>.supabase.co/functions/v1/scan-odds

# Telegram (alertas — Fase 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EDGE_MIN=0.03

# Parâmetros do motor (defaults sensatos; podem ser alterados na UI)
ENGINE_EDGE_THRESHOLD=0.02
ENGINE_DEVIG_METHOD=shin
ENGINE_KELLY_FRACTION=0.25
ENGINE_SHARP_SOURCE=pinnacle
ENGINE_STAKE_CAP=0.05
ENGINE_BANKROLL=1000
ENGINE_SPORT=soccer
ENGINE_MAX_FIXTURES=50
