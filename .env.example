# ==========================================================================
# NumeiroTips — variáveis de ambiente
# Copia para .env.local (frontend) e configura no Supabase / Vercel.
# A app FUNCIONA SEM NENHUMA destas chaves: cai no motor mock local
# (dados simulados realistas) para validar o pipeline de ponta a ponta.
# ==========================================================================

# --- Frontend (Vite, prefixo VITE_) ---
# Modo de dados:
#   "mock"       (default) gerador local, sem chaves
#   "theoddsapi" polling client-side do The Odds API (grátis) — motor no browser
#   "live"       Supabase Realtime (value bets calculadas no servidor)
VITE_DATA_MODE=mock

# The Odds API (grátis: the-odds-api.com/signup) — cobre Pinnacle, Betfair,
# Betclic e 1xBet. Para uso PESSOAL podes pôr a chave no browser (é tua).
# Necessária quando VITE_DATA_MODE=theoddsapi.
VITE_THE_ODDS_API_KEY=

# Supabase (só para VITE_DATA_MODE=live)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Backend / Edge Functions (NUNCA expor no frontend) ---
# Fonte de dados do servidor: "theoddsapi" (grátis, default) ou "oddspapi" (pago)
ENGINE_DATA_SOURCE=theoddsapi

# The Odds API (server-side) — grátis, cobre as 4 casas. 500 créditos/mês;
# cada chamada custa nº_mercados × nº_regiões créditos → sê frugal.
THE_ODDS_API_KEY=
THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
THE_ODDS_API_REGIONS=eu
THE_ODDS_API_MARKETS=h2h,totals
THE_ODDS_API_BOOKMAKERS=pinnacle,betfair_ex_eu,betclic,onexbet
THE_ODDS_API_SPORTS=soccer_epl,soccer_spain_la_liga,soccer_italy_serie_a,soccer_france_ligue_one,soccer_germany_bundesliga,soccer_portugal_primeira_liga

# OddsPapi — alternativa paga (Betclic, 1xBet, Pinnacle, Betfair; WebSocket no Pro)
ODDSPAPI_API_KEY=
ODDSPAPI_BASE_URL=https://api.oddspapi.io/v1
ODDSPAPI_WS_URL=wss://stream.oddspapi.io/v1

# Supabase service role (só no servidor / edge functions)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# URL da Edge Function scan-odds (para o Vercel Cron a acionar)
SUPABASE_FUNCTION_URL=https://<projeto>.supabase.co/functions/v1/scan-odds

# Telegram (alertas — Fase 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EDGE_MIN=0.03

# Parâmetros do motor (defaults sensatos; podem ser alterados na UI)
ENGINE_EDGE_THRESHOLD=0.02
ENGINE_DEVIG_METHOD=shin
ENGINE_KELLY_FRACTION=0.25
ENGINE_SHARP_SOURCE=pinnacle
ENGINE_STAKE_CAP=0.05
ENGINE_BANKROLL=1000
ENGINE_SPORT=soccer
ENGINE_MAX_FIXTURES=50
