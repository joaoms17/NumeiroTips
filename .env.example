# ==========================================================================
# NumeiroTips — variáveis de ambiente
# Copia para .env.local (frontend) e configura no Supabase / Vercel.
# A app FUNCIONA SEM NENHUMA destas chaves: cai no motor mock local
# (dados simulados realistas) para validar o pipeline de ponta a ponta.
# ==========================================================================

# --- Frontend (Vite, prefixo VITE_) ---
# Modo de dados:
#   "mock"       (default) gerador local, sem chaves
#   "theoddsapi" polling client-side do The Odds API (grátis) — motor no browser
#                ⚠ gasta créditos a cada scan/abertura; bom para testar, não p/ uso contínuo
#   "live"       Supabase Realtime (value bets calculadas no servidor)
# NOTA: se definires VITE_ODDS_SNAPSHOT_URL (abaixo), a app usa o modo 'snapshot'
# automaticamente (recomendado) — ignora o polling client-side.
VITE_DATA_MODE=mock

# ── CAMINHO RECOMENDADO (longo prazo): modo 'snapshot' ───────────────────────
# A app lê um snapshot.json gerado por um COLETOR AGENDADO (GitHub Actions, ver
# .github/workflows/collect-odds.yml). Assim o browser NUNCA chama o The Odds API
# → consumo de créditos fixo e previsível (definido pelo cron), e a app está
# sempre cheia. Aponta para o raw da branch `odds-cache`:
VITE_ODDS_SNAPSHOT_URL=https://raw.githubusercontent.com/joaoms17/NumeiroTips/odds-cache/snapshot.json

# The Odds API (grátis: the-odds-api.com/signup) — cobre Pinnacle, Betfair,
# Betclic e 1xBet. Só necessária no modo 'theoddsapi' (polling no browser).
# No modo 'snapshot' NÃO precisas desta no cliente (a chave vive nos secrets do
# GitHub Actions como THE_ODDS_API_KEY).
VITE_THE_ODDS_API_KEY=

# API-Football (grátis: dashboard.api-football.com) — stats reais de 1200+ ligas
# (forma, golos, over%, BTTS, h2h) carregadas no detalhe de cada aposta.
# 100 pedidos/dia; a app faz cache. Opcional.
VITE_API_FOOTBALL_KEY=

# Supabase (só para VITE_DATA_MODE=live)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Backend / Edge Functions (NUNCA expor no frontend) ---
# Fonte de dados do servidor: "theoddsapi" (grátis, default) ou "oddspapi" (pago)
ENGINE_DATA_SOURCE=theoddsapi

# The Odds API (server-side) — grátis, cobre as 4 casas. 500 créditos/mês;
# cada chamada custa nº_mercados × nº_regiões créditos → sê frugal.
THE_ODDS_API_KEY=
THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
THE_ODDS_API_REGIONS=eu
# h2h (1X2), totals (over/under) e spreads (handicap) são grátis (featured).
# Cada mercado extra custa +1 crédito por chamada — atenção à quota.
THE_ODDS_API_MARKETS=h2h,totals,spreads
THE_ODDS_API_BOOKMAKERS=pinnacle,betfair_ex_eu,betclic,onexbet
# Ligas a varrer. ATENÇÃO À ÉPOCA: em jun–jul/2026 as ligas domésticas estão
# paradas; o que decorre é o Mundial (soccer_fifa_world_cup). Quando a época
# recomeçar (~ago), troca para: soccer_epl,soccer_spain_la_liga,soccer_italy_serie_a,...
THE_ODDS_API_SPORTS=soccer_fifa_world_cup,soccer_brazil_campeonato,soccer_conmebol_copa_libertadores,soccer_usa_mls,soccer_sweden_allsvenskan,soccer_norway_eliteserien

# --- Coletor agendado (GitHub Actions → branch odds-cache) ---
# Fonte do coletor: 'theoddsapi' (500/MÊS) ou 'apifootball' (100/DIA, reseta
# diário → NUNCA ficas um mês morto). Recomendado: apifootball.
COLLECT_SOURCE=theoddsapi
# API-Football: ligas no formato leagueId:season, separadas por vírgula.
# Mundial 2026 = 1:2026. (MLS=253, Brasileirão=71, Libertadores=13, ...)
AF_LEAGUES=1:2026
# Nº máx. de jogos a pedir odds por execução (1 pedido/jogo — protege os 100/dia).
AF_MAX_FIXTURES=25

# OddsPapi — alternativa paga (Betclic, 1xBet, Pinnacle, Betfair; WebSocket no Pro)
ODDSPAPI_API_KEY=
ODDSPAPI_BASE_URL=https://api.oddspapi.io/v1
ODDSPAPI_WS_URL=wss://stream.oddspapi.io/v1

# Supabase service role (só no servidor / edge functions)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# URL da Edge Function scan-odds (para o Vercel Cron a acionar)
SUPABASE_FUNCTION_URL=https://<projeto>.supabase.co/functions/v1/scan-odds

# Visão AI da página Análise — MULTI-FORNECEDOR (usa a 1ª chave que existir).
# Todos têm tier GRÁTIS menos a Anthropic. Chave SÓ no servidor.
# Sem nenhuma, a página mostra a análise automática (determinística) na mesma.
GEMINI_API_KEY=          # Google Gemini (grátis, recomendado) — aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=            # Groq / Llama (grátis, rápido) — console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=       # Claude (pago)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# API-Football no servidor (para o proxy /api/football) — alternativa à VITE_.
API_FOOTBALL_KEY=

# Telegram (alertas — Fase 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EDGE_MIN=0.03

# Parâmetros do motor (defaults sensatos; podem ser alterados na UI)
ENGINE_EDGE_THRESHOLD=0.02
ENGINE_DEVIG_METHOD=shin
ENGINE_KELLY_FRACTION=0.25
ENGINE_SHARP_SOURCE=pinnacle
ENGINE_STAKE_CAP=0.05
ENGINE_BANKROLL=1000
ENGINE_SPORT=soccer
ENGINE_MAX_FIXTURES=50
